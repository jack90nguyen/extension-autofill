{
  "manifest_version": 3,
  "name": "Visible Form Autofill",
  "version": "1.0.0",
  "description": "Autofills only visible and interactable form fields for frontend testing.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "Visible Autofill",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/visibility.js",
        "utils/interactable.js",
        "utils/viewport.js",
        "content/autofill.js",
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
